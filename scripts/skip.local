#!/bin/bash
# This script runs the skip tool with the local skipstone checkout
SKIPDIR=$(dirname $(realpath $0))
# SKIP_COMMAND_OVERRIDE is used by SkipBridge's skip.yml
export SKIP_COMMAND_OVERRIDE=${SKIPDIR}/.build/arm64-apple-macosx/debug/SkipRunner
swift run --package-path ${SKIPDIR} SkipRunner "${@}"
